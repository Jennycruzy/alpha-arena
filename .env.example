# ─── Alpha Arena Environment Configuration ────────────────────────────────────
# Copy this to .env and fill in your values.
# In DEMO_MODE=true, no real keys are needed — the app runs with simulated data.

# ─── Demo / Dev Mode ──────────────────────────────────────────────────────────
# Set to false and fill in keys below when ready for real trading
DEMO_MODE=true

# ─── Competition Settings ─────────────────────────────────────────────────────
ENTRY_FEE_USD=0.5                    # Minimum entry: $0.5 USDC
COMPETITION_DURATION_SECONDS=600     # 10 minutes (set to 60 for quick testing)
AGENT_LOOP_INTERVAL_SECONDS=25       # How often agents trade
LEADERBOARD_UPDATE_INTERVAL_SECONDS=5

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000    # Next.js frontend

# ─── X Layer Mainnet (gas paid in OKB) ───────────────────────────────────────
CHAIN_ID=196
RPC_URL=https://rpc.xlayer.tech
EXPLORER_URL=https://www.okx.com/explorer/xlayer

# ─── Arena Operator Wallet ────────────────────────────────────────────────────
# This wallet needs OKB for gas (calls routeFunds + distributePayout on ArenaVault)
ARENA_WALLET_PRIVATE_KEY=
ARENA_WALLET_ADDRESS=

# ─── ArenaVault Contract ──────────────────────────────────────────────────────
# Auto-written by deploy.js after contract deployment
ARENA_VAULT_ADDRESS=

# Contract deployer wallet (can be same as ARENA_WALLET, needs OKB for gas)
DEPLOYER_PRIVATE_KEY=

# ─── Token Addresses on X Layer Mainnet ───────────────────────────────────────
USDC_ADDRESS=0x74b7f16337b8972027f6196a17a631ac6de26d22
WETH_ADDRESS=0x5a77f1443d16ee5761d310e38b7e24ce946cf484
WBTC_ADDRESS=0xea034fb02eb1808c2cc3adbc15f447b93cbe08e1

# ─── OKX OnchainOS API ────────────────────────────────────────────────────────
# Get keys at: https://www.okx.com/web3/developer
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# ─── AI Provider — pick ONE public provider ─────────────────────────────────
# Set AI_PROVIDER to "openai" or "claude", then add the matching key only.

AI_PROVIDER=openai          # "openai" or "claude"

OPENAI_API_KEY=             # if AI_PROVIDER=openai
ANTHROPIC_API_KEY=          # if AI_PROVIDER=claude

# Venice AI — private reasoning (optional, for Private Arena mode)
# Get key at https://venice.ai
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b  # optional

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Get a free project ID at https://cloud.reown.com (WalletConnect)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# ─── OKX Explorer Verification (optional) ────────────────────────────────────
OKXSCAN_API_KEY=

# ─── Stop Loss ────────────────────────────────────────────────────────────────
STOP_LOSS_PERCENT=15
MAX_SLIPPAGE_PERCENT=2
